{
  "name": "nodeoct",
  "private": true,
  "version": "0.1.0",
  "description": "Notes app plotted on a 3-axis cube with 8 labelable sub-regions",
  "author": "skc45",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "dist": "npm run build && electron-builder --win portable",
    "dist:installer": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "@react-three/drei": "^10.0.6",
    "@react-three/fiber": "^9.1.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.175.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/three": "^0.175.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^35.1.2",
    "electron-builder": "^25.1.8",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.nodeoct.app",
    "productName": "Nodeoct",
    "copyright": "Copyright © 2026 skc45",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "Nodeoct-${version}-portable.${ext}",
      "signAndEditExecutable": false
    }
  }
}
